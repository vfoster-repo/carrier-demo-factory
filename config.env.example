# Carrier Demo Factory — Configuration
# Copy this file to config.env and fill in your values before running.
#
#   cp config.env.example config.env
#
# config.env is gitignored — never commit it.

# The domain where demos will be hosted.
# Used in generated HTML footers, CTA links, and deployment URLs.
# Example: your-domain.com
AGENT_DOMAIN=your-domain.com

# Contact email embedded in generated HTML (CTA buttons, help links).
# Example: hello@your-domain.com
AGENT_EMAIL=hello@your-domain.com

# Absolute path to the directory where generated companies are stored on the VPS.
COMPANIES_DIR=/opt/carrier-factory/companies

# Absolute path to the agent working directory on the VPS.
AGENT_DIR=/opt/carrier-factory
